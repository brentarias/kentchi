# Cloudinary credentials for build-time gallery fetch.
# Copy this file to ".env" and fill in real values from your Cloudinary dashboard.
# .env is gitignored; .env.example is committed as a template.

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# asset_folder path inside Cloudinary that holds gallery images.
# This site's actual value is "Kentchi/Gallery" (case-sensitive, no leading or
# trailing slash). The fallback "gallery" exists only so the SDK has a default
# during local development experiments; a real build needs the real path.
CLOUDINARY_GALLERY_FOLDER=Kentchi/Gallery
