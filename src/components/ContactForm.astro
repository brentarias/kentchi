---
import { t, type Lang, defaultLang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const i = t(lang);
---

<form class="max-w-xl mx-auto space-y-6" onsubmit="event.preventDefault()">
  <div>
    <label for="name" class="block text-sm font-medium mb-1">{i.contact.nameLabel}</label>
    <input
      type="text"
      id="name"
      name="name"
      class="w-full border border-brand-warm-gray rounded px-4 py-2 focus:outline-none focus:ring-2 focus:ring-brand-gold"
    />
  </div>
  <div>
    <label for="email" class="block text-sm font-medium mb-1">{i.contact.emailLabel}</label>
    <input
      type="email"
      id="email"
      name="email"
      class="w-full border border-brand-warm-gray rounded px-4 py-2 focus:outline-none focus:ring-2 focus:ring-brand-gold"
    />
  </div>
  <div>
    <label for="message" class="block text-sm font-medium mb-1">{i.contact.messageLabel}</label>
    <textarea
      id="message"
      name="message"
      rows="5"
      class="w-full border border-brand-warm-gray rounded px-4 py-2 focus:outline-none focus:ring-2 focus:ring-brand-gold"
    ></textarea>
  </div>
  <button
    type="submit"
    class="bg-brand-dark text-white px-8 py-3 rounded hover:bg-brand-gold transition-colors uppercase tracking-wide text-sm"
  >
    {i.contact.submitButton}
  </button>
</form>
