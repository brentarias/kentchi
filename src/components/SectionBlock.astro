---
interface Props {
  heading?: string;
  class?: string;
}

const { heading, class: className = '' } = Astro.props;
---

<section class:list={['py-16 px-6 bg-white', className]}>
  <div class="max-w-4xl mx-auto">
    {heading && (
      <h2 class="text-2xl md:text-4xl font-heading text-center mb-8">{heading}</h2>
    )}
    <slot />
  </div>
</section>
