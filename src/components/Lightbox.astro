---
// Lightbox.astro — drop once on a page. Any <button data-lightbox-src="/path/to.jpg">
// will open a fullscreen <dialog> showing that image when clicked. When more than
// one lightbox trigger is present on the page, previous/next buttons (and the
// left/right arrow keys) cycle through them in document order.
---

<dialog id="lightbox" class="lightbox">
  <button id="lightbox-close" type="button" aria-label="Close" class="lightbox__close">&times;</button>
  <button id="lightbox-prev" type="button" aria-label="Previous image" class="lightbox__nav lightbox__nav--prev">&#8592;</button>
  <img id="lightbox-img" alt="" />
  <button id="lightbox-next" type="button" aria-label="Next image" class="lightbox__nav lightbox__nav--next">&#8594;</button>
</dialog>

<style>
  .lightbox {
    border: 0;
    background: transparent;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
  }
  .lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0.92);
  }
  .lightbox img {
    display: block;
    max-width: 95vw;
    max-height: 92vh;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .lightbox__close,
  .lightbox__nav {
    position: fixed;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    line-height: 1;
    border: 1px solid rgba(255, 255, 255, 0.35);
    cursor: pointer;
    z-index: 1;
  }
  .lightbox__close:hover,
  .lightbox__nav:hover { background: rgba(255, 255, 255, 0.22); }
  .lightbox__close {
    top: 1rem;
    right: 1.25rem;
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1.75rem;
  }
  .lightbox__nav {
    top: 50%;
    transform: translateY(-50%);
    width: 3rem;
    height: 3rem;
    font-size: 1.5rem;
  }
  .lightbox__nav--prev { left: 1.25rem; }
  .lightbox__nav--next { right: 1.25rem; }
  .lightbox__nav[hidden] { display: none; }
</style>

<script>
  const dlg = document.getElementById('lightbox') as HTMLDialogElement | null;
  const img = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const closeBtn = document.getElementById('lightbox-close');
  const prevBtn = document.getElementById('lightbox-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('lightbox-next') as HTMLButtonElement | null;

  let triggers: HTMLElement[] = [];
  let index = 0;

  function render() {
    if (!img || triggers.length === 0) return;
    const t = triggers[index];
    img.src = t.getAttribute('data-lightbox-src') || '';
    img.alt = t.getAttribute('data-lightbox-alt') || '';
  }

  function step(delta: number) {
    if (triggers.length === 0) return;
    index = (index + delta + triggers.length) % triggers.length;
    render();
  }

  if (dlg && img && closeBtn && prevBtn && nextBtn) {
    document.addEventListener('click', (e) => {
      const trigger = (e.target as HTMLElement)?.closest('[data-lightbox-src]') as HTMLElement | null;
      if (!trigger) return;
      triggers = Array.from(document.querySelectorAll<HTMLElement>('[data-lightbox-src]'));
      index = triggers.indexOf(trigger);
      if (index < 0) return;
      const showNav = triggers.length > 1;
      prevBtn.hidden = !showNav;
      nextBtn.hidden = !showNav;
      render();
      dlg.showModal();
    });
    closeBtn.addEventListener('click', () => dlg.close());
    prevBtn.addEventListener('click', () => step(-1));
    nextBtn.addEventListener('click', () => step(1));
    // Click on backdrop closes
    dlg.addEventListener('click', (e) => {
      if (e.target === dlg) dlg.close();
    });
    // Arrow-key navigation
    dlg.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') step(-1);
      else if (e.key === 'ArrowRight') step(1);
    });
  }
</script>
