---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t, type Lang, defaultLang } from '../i18n';

interface Props {
  title: string;
  lang?: Lang;
  /** Optional per-page description. Falls back to the i18n site description. */
  description?: string;
  /** Optional per-page banner image path (must start with "/", ideally 1200x630). Falls back to the keyhole banner. */
  ogImage?: string;
}

const { title, lang = defaultLang, description, ogImage } = Astro.props;
const i = t(lang);

const siteName = i.meta.siteName;
const metaDescription = description ?? i.meta.siteDescription;

// Two social images: a 1200x630 banner (used large by most platforms) and an
// 800x800 square companion (some thumbnail-oriented contexts prefer square).
// Platforms choose which to use; we can't target per-platform — see the OG
// notes in the project history. The banner is overridable per page.
const ogImagePath = ogImage ?? '/og-keyhole-large.jpg';
const ogSquarePath = '/og-keyhole-square-notext.jpg';

// Build absolute URLs for OG/Twitter. Astro.site comes from astro.config.mjs.
// When the dev server runs without a configured site, fall back to the request origin.
const origin = Astro.site?.origin ?? Astro.url.origin;
const canonicalUrl = new URL(Astro.url.pathname, origin).toString();
const ogImageUrl = new URL(ogImagePath, origin).toString();
const ogSquareUrl = new URL(ogSquarePath, origin).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/keyhole.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#34045C" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="description" content={metaDescription} />

    <!-- Open Graph (Facebook, LinkedIn, Slack, Discord, iMessage) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <!-- Primary 1200x630 banner -->
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={siteName} />
    <!-- Square 800x800 companion (thumbnail-oriented contexts) -->
    <meta property="og:image" content={ogSquareUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="800" />
    <meta property="og:image:alt" content={siteName} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={siteName} />

    <title>{title}</title>
    <!-- gtag.js — only load on the canonical domain so deploy-hash URLs, the old
         kentchi.netlify.app, and localhost don't pollute analytics. -->
    <script is:inline>
      if (location.hostname === 'www.kentosborn.studio') {
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-FEGK7PWBTV';
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-FEGK7PWBTV');
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
