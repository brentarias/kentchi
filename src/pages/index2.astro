---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionBlock from '../components/SectionBlock.astro';
import { t } from '../i18n';

const i = t('en');
---

<Layout title={i.home.title} description={i.home.metaDescription}>
  <Hero bgImage="/images/hero-portrait.avif" heading={i.home.heroHeadline} text={i.home.heroSubheadline}>
    <div class="mt-8 flex flex-wrap gap-4 justify-center">
      <a href="/decks" class="px-6 py-3 bg-brand-gold text-brand-dark font-heading uppercase tracking-wide text-sm hover:opacity-90 transition-opacity">{i.home.heroCtaDecks}</a>
      <a href="/art" class="px-6 py-3 border border-white text-white font-heading uppercase tracking-wide text-sm hover:bg-white hover:text-brand-dark transition-colors">{i.home.heroCtaArt}</a>
      <a href="/experiences" class="px-6 py-3 border border-white text-white font-heading uppercase tracking-wide text-sm hover:bg-white hover:text-brand-dark transition-colors">{i.home.heroCtaEvents}</a>
    </div>
  </Hero>

  <SectionBlock>
    <p class="text-center text-lg md:text-xl leading-relaxed max-w-2xl mx-auto">{i.home.welcomeText}</p>
  </SectionBlock>

  <SectionBlock heading={i.home.offersHeading} class="bg-brand-light">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="space-y-3">
        <h3 class="text-xl font-heading text-brand-gold">{i.home.decksTitle}</h3>
        <p class="leading-relaxed">{i.home.decksText}</p>
        <a href="/decks" class="inline-block text-brand-sage hover:text-brand-gold transition-colors font-heading uppercase tracking-wide text-sm">Explore &rarr;</a>
      </div>
      <div class="space-y-3">
        <h3 class="text-xl font-heading text-brand-gold">{i.home.artTitle}</h3>
        <p class="leading-relaxed">{i.home.artText}</p>
        <a href="/art" class="inline-block text-brand-sage hover:text-brand-gold transition-colors font-heading uppercase tracking-wide text-sm">Explore &rarr;</a>
      </div>
      <div class="space-y-3">
        <h3 class="text-xl font-heading text-brand-gold">{i.home.eventsTitle}</h3>
        <p class="leading-relaxed">{i.home.eventsText}</p>
        <a href="/experiences" class="inline-block text-brand-sage hover:text-brand-gold transition-colors font-heading uppercase tracking-wide text-sm">Explore &rarr;</a>
      </div>
      <div class="space-y-3">
        <h3 class="text-xl font-heading text-brand-gold">{i.home.musicTitle}</h3>
        <p class="leading-relaxed">{i.home.musicText}</p>
        <a href="/music" class="inline-block text-brand-sage hover:text-brand-gold transition-colors font-heading uppercase tracking-wide text-sm">Listen &rarr;</a>
      </div>
    </div>
  </SectionBlock>

  <section class="relative py-20 px-4 md:px-8 overflow-hidden">
    <div class="relative max-w-5xl mx-auto rounded-3xl bg-brand-purple text-white py-16 px-6 md:py-20 md:px-14 overflow-hidden shadow-[0_30px_80px_-30px_rgba(52,4,92,0.55)]">
      <div
        class="absolute inset-0"
        style="background: radial-gradient(ellipse 70% 55% at 50% 0%, rgba(208,172,104,0.28) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <span class="ar-orb absolute -top-10 -left-12 w-60 h-60 rounded-full bg-fuchsia-500/30 blur-3xl"></span>
        <span class="ar-orb-slow absolute -bottom-10 -right-14 w-72 h-72 rounded-full bg-amber-300/25 blur-3xl"></span>
      </div>
      <span aria-hidden="true" class="absolute top-6  left-8  text-brand-gold/80 text-2xl select-none">✦</span>
      <span aria-hidden="true" class="absolute top-10 right-10 text-brand-gold/70 text-3xl select-none">✧</span>
      <span aria-hidden="true" class="absolute bottom-8 left-14 text-brand-gold/70 text-xl select-none">✦</span>
      <span aria-hidden="true" class="absolute bottom-12 right-20 text-brand-gold/80 text-2xl select-none">✧</span>

      <div class="relative text-center max-w-2xl mx-auto">
        <p class="text-xs uppercase tracking-[0.35em] text-brand-gold mb-4">Powered by Artivive</p>
        <h2 class="text-2xl md:text-4xl font-heading mb-6">{i.home.arHeading}</h2>
        <p class="text-lg leading-relaxed text-white/95">{i.home.arText}</p>
      </div>
    </div>
  </section>

  <SectionBlock heading={i.home.followHeading}>
    <p class="text-center text-lg mb-10">{i.home.followIntro}</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <a href="https://www.instagram.com/inkentations/" target="_blank" rel="noopener noreferrer" class="bg-brand-light text-center space-y-3 border border-brand-gold/30 p-6 hover:border-brand-gold transition-colors block">
        <svg class="w-8 h-8 mx-auto text-brand-gold" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        <h3 class="font-heading text-xs tracking-tight wrap-break-word">{i.home.inkentationsTitle}</h3>
        <p class="text-sm leading-relaxed">{i.home.inkentationsText}</p>
      </a>
      <a href="https://www.instagram.com/magnetic_magi_oracle/" target="_blank" rel="noopener noreferrer" class="bg-brand-light text-center space-y-3 border border-brand-gold/30 p-6 hover:border-brand-gold transition-colors block">
        <svg class="w-8 h-8 mx-auto text-brand-gold" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        <h3 class="font-heading text-xs tracking-tight wrap-break-word">{i.home.magneticMagiTitle}</h3>
        <p class="text-sm leading-relaxed">{i.home.magneticMagiText}</p>
      </a>
      <a href="https://www.instagram.com/shinan_visionary_arts/" target="_blank" rel="noopener noreferrer" class="bg-brand-light text-center space-y-3 border border-brand-gold/30 p-6 hover:border-brand-gold transition-colors block">
        <svg class="w-8 h-8 mx-auto text-brand-gold" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        <h3 class="font-heading text-xs tracking-tight wrap-break-word">{i.home.shinanArtTitle}</h3>
        <p class="text-sm leading-relaxed">{i.home.shinanArtText}</p>
      </a>
      <a href="https://www.instagram.com/shinanoraculo/" target="_blank" rel="noopener noreferrer" class="bg-brand-light text-center space-y-3 border border-brand-gold/30 p-6 hover:border-brand-gold transition-colors block">
        <svg class="w-8 h-8 mx-auto text-brand-gold" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        <h3 class="font-heading text-xs tracking-tight wrap-break-word">{i.home.shinanOraculoTitle}</h3>
        <p class="text-sm leading-relaxed">{i.home.shinanOraculoText}</p>
      </a>
    </div>
    <p class="text-center mt-8 text-lg font-heading">
      {i.home.finalCta}
      <a href="/contact" class="text-brand-gold underline hover:text-brand-sage transition-colors ml-2">Get in touch &rarr;</a>
    </p>
  </SectionBlock>
</Layout>

<style>
  @keyframes ar-drift-a {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50%      { transform: translate3d(14px, -10px, 0) scale(1.06); }
  }
  @keyframes ar-drift-b {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50%      { transform: translate3d(-12px, 10px, 0) scale(1.08); }
  }
  .ar-orb      { animation: ar-drift-a 11s ease-in-out infinite; }
  .ar-orb-slow { animation: ar-drift-b 15s ease-in-out infinite; }

  @media (prefers-reduced-motion: reduce) {
    .ar-orb, .ar-orb-slow { animation: none; }
  }
</style>
