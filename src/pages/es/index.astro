---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import SectionBlock from '../../components/SectionBlock.astro';
import { t } from '../../i18n';

const i = t('es');
---

<Layout title={i.home.title} lang="es">
  <Hero bgImage="/images/hero-portrait.avif" />

  <!-- Mission -->
  <SectionBlock heading={i.home.missionHeading}>
    <p class="text-center text-lg md:text-xl leading-relaxed italic max-w-2xl mx-auto">{i.home.missionText}</p>
  </SectionBlock>

  <!-- Offerings -->
  <SectionBlock heading={i.home.offeringsHeading}>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center space-y-4">
        <h3 class="text-xl font-heading text-brand-gold">{i.home.ceremoniesTitle}</h3>
        <p class="leading-relaxed">{i.home.ceremoniesText}</p>
        <a href="/es/gatherings" class="inline-block text-brand-sage hover:text-brand-gold transition-colors font-heading uppercase tracking-wide text-sm">{i.home.ceremoniesLink} &rarr;</a>
      </div>
      <div class="text-center space-y-4">
        <h3 class="text-xl font-heading text-brand-gold">{i.home.artTitle}</h3>
        <p class="leading-relaxed">{i.home.artText}</p>
        <a href="/es/art-music" class="inline-block text-brand-sage hover:text-brand-gold transition-colors font-heading uppercase tracking-wide text-sm">{i.home.artLink} &rarr;</a>
      </div>
      <div class="text-center space-y-4">
        <h3 class="text-xl font-heading text-brand-gold">{i.home.storeTitle}</h3>
        <p class="leading-relaxed">{i.home.storeText}</p>
        <a href="/es/store" class="inline-block text-brand-sage hover:text-brand-gold transition-colors font-heading uppercase tracking-wide text-sm">{i.home.storeLink} &rarr;</a>
      </div>
    </div>
  </SectionBlock>

  <!-- Instagram accounts — pattern background (fixed body bg shows through) -->
  <section class="relative py-16 px-6">
    <div class="absolute inset-0" style="background-color: rgba(213, 215, 201, 0.6);"></div>
    <div class="relative max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-4xl font-heading text-center mb-8">{i.home.followHeading}</h2>
    <p class="text-center text-lg mb-10">{i.home.followText}</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-2xl mx-auto">
      <div class="bg-white text-center space-y-4 border border-brand-gold/30 p-8">
        <svg class="w-8 h-8 mx-auto text-brand-gold" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        <h3 class="font-heading text-lg">{i.home.inkentationsTitle}</h3>
        <p class="text-sm leading-relaxed">{i.home.inkentationsText}</p>
        <a
          href="https://www.instagram.com/inkentations"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-6 py-2 border border-brand-gold text-brand-dark font-heading uppercase tracking-widest text-xs hover:bg-brand-gold transition-colors"
        >
          {i.home.inkentationsCta}
        </a>
      </div>
      <div class="bg-white text-center space-y-4 border border-brand-gold/30 p-8">
        <svg class="w-8 h-8 mx-auto text-brand-gold" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        <h3 class="font-heading text-lg">{i.home.shinanArtTitle}</h3>
        <p class="text-sm leading-relaxed">{i.home.shinanArtText}</p>
        <a
          href="https://www.instagram.com/shinan_visionary_arts/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-6 py-2 border border-brand-gold text-brand-dark font-heading uppercase tracking-widest text-xs hover:bg-brand-gold transition-colors"
        >
          {i.home.shinanArtCta}
        </a>
      </div>
    </div>
    </div>
  </section>

  <!-- Testimonial -->
  <SectionBlock heading={i.home.testimonialHeading}>
    <blockquote class="max-w-2xl mx-auto text-center text-xl md:text-2xl italic leading-relaxed text-brand-warm-gray">
      {i.home.testimonial}
    </blockquote>
  </SectionBlock>
</Layout>
