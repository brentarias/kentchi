---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import SectionBlock from '../../components/SectionBlock.astro';
import Gallery from '../../components/Gallery.astro';
import { t } from '../../i18n';

const i = t('es');

const galleryImages = Array.from({ length: 15 }, (_, idx) => {
  const num = idx + 1;
  const ext = [5, 8, 12].includes(num) ? 'jpeg' : 'jpg';
  return { src: `/images/gallery/art-${num}.${ext}`, alt: `Pieza de arte visionario ${num}` };
});
---

<Layout title={i.artMusic.title} lang="es">
  <Hero heading={i.nav.artMusic} />

  <SectionBlock heading={i.artMusic.artHeading}>
    <p class="text-base leading-relaxed mb-8">{i.artMusic.artText}</p>
  </SectionBlock>

  <SectionBlock heading={i.artMusic.galleryHeading} class="bg-brand-light">
    <Gallery images={galleryImages} />
  </SectionBlock>

  <SectionBlock heading={i.artMusic.musicHeading}>
    <p class="text-base leading-relaxed mb-8">{i.artMusic.musicText}</p>

    <div class="max-w-lg mx-auto">
      <iframe
        width="100%"
        height="450"
        scrolling="no"
        frameborder="no"
        allow="autoplay"
        src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/kent-ucky&color=%23ff5500&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true"
      ></iframe>
    </div>
  </SectionBlock>
</Layout>
