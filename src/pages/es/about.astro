---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import SectionBlock from '../../components/SectionBlock.astro';
import { t } from '../../i18n';

const i = t('es');
---

<Layout title={i.about.title} lang="es">
  <Hero heading={i.about.heading} />

  <SectionBlock>
    <div class="max-w-2xl mx-auto space-y-6 text-base leading-relaxed">
      <p>{i.about.body}</p>
      <p>{i.about.body2}</p>
      <p>{i.about.body3}</p>
    </div>
  </SectionBlock>

  <section class="relative py-16 px-6">
    <div class="absolute inset-0" style="background-color: rgba(213, 215, 201, 0.6);"></div>
    <div class="relative max-w-2xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-heading mb-6">{i.about.philosophyHeading}</h2>
      <blockquote class="text-xl md:text-2xl italic leading-relaxed text-brand-dark">{i.about.philosophy}</blockquote>
    </div>
  </section>

  <SectionBlock>
    <p class="text-center text-lg font-heading">
      {i.about.cta}
      <a href="/es/contact" class="text-brand-gold underline hover:text-brand-sage transition-colors ml-2">Contactar a Kentchi &rarr;</a>
    </p>
  </SectionBlock>
</Layout>
