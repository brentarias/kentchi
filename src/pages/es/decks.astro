---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import SectionBlock from '../../components/SectionBlock.astro';
import { t } from '../../i18n';

const i = t('es');
---

<Layout title={i.decks.title} lang="es">
  <Hero heading={i.decks.heading} text={i.decks.subheading} />

  <SectionBlock>
    <p class="text-center text-lg leading-relaxed max-w-2xl mx-auto">{i.decks.intro}</p>
  </SectionBlock>

  <SectionBlock heading={i.decks.featuredHeading} class="bg-brand-light">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
      <div class="space-y-4">
        <div class="flex items-start gap-4">
          <img src="/images/shinan-product.jpg" alt="Oráculo Shinan" class="w-32 h-auto rounded shadow flex-shrink-0" />
          <div class="space-y-2">
            <h3 class="text-xl font-heading text-brand-gold">{i.decks.shinanTitle}</h3>
            <p class="text-base leading-relaxed">{i.decks.shinanText}</p>
          </div>
        </div>
      </div>
      <div class="space-y-4">
        <h3 class="text-xl font-heading text-brand-gold">{i.decks.magneticTitle}</h3>
        <p class="text-base leading-relaxed">{i.decks.magneticText}</p>
      </div>
    </div>
  </SectionBlock>

  <SectionBlock heading={i.decks.whereHeading}>
    <p class="text-center text-lg leading-relaxed max-w-2xl mx-auto mb-6">{i.decks.whereText}</p>
    <div class="text-center">
      <a href="/es/contact" class="inline-block px-8 py-3 bg-brand-dark text-white font-heading uppercase tracking-wide text-sm hover:bg-brand-gold hover:text-brand-dark transition-colors">{i.decks.whereCtaContact}</a>
    </div>
  </SectionBlock>

  <SectionBlock heading={i.decks.teachingHeading} class="bg-brand-light">
    <p class="text-center text-lg leading-relaxed max-w-2xl mx-auto mb-8">{i.decks.teachingText}</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/es/events" class="inline-block px-6 py-3 border border-brand-dark text-brand-dark font-heading uppercase tracking-wide text-sm hover:bg-brand-dark hover:text-white transition-colors">{i.decks.ctaEvents}</a>
      <a href="/es/contact" class="inline-block px-6 py-3 bg-brand-dark text-white font-heading uppercase tracking-wide text-sm hover:bg-brand-gold hover:text-brand-dark transition-colors">{i.decks.ctaContact}</a>
    </div>
  </SectionBlock>
</Layout>
