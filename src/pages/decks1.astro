---
import Layout from '../layouts/Layout.astro';
import { t } from '../i18n';

const i = t('en');

// Catalog tiles for the 2x2 grid below the hero.
const catalog = [
  {
    name: 'Shinan Oracle',
    sub: 'Shipibo · Bilingual Deck',
    note: 'Kené designs, icaros, AR-enhanced.',
    image: '/images/shinan-product.jpg',
    accent: 'from-amber-200 via-rose-300 to-emerald-300',
    tilt: 'tilt-tl',
  },
  {
    name: 'Magnetic Magi',
    sub: 'Manifestation Deck',
    note: 'Magnetic energy, AR overlays.',
    image: '/images/magnetic-magi-product.jpg',
    accent: 'from-amber-200 via-fuchsia-300 to-violet-300',
    tilt: 'tilt-tr',
  },
  {
    name: 'Through the Keyhole',
    sub: 'Visionary 3rd-Eye · Coming Soon',
    note: '16 years in the making.',
    image: '/images/through-the-keyhole-preview.jpg',
    accent: 'from-teal-200 via-cyan-200 to-violet-300',
    tilt: 'tilt-bl',
  },
  {
    name: 'El Estimado',
    sub: 'Illustrated Memoir',
    note: 'A journey through Mexico, page-by-page.',
    image: '/images/el-estimado-front.jpg',
    accent: 'from-amber-200 via-brand-gold to-rose-300',
    tilt: 'tilt-br',
  },
];
---

<Layout title={i.decks.title} description={i.decks.metaDescription}>
  <!-- ============================================================ -->
  <!-- HERO — KMP imprint up front. Cream + purple boutique palette  -->
  <!-- with cursor-follow spotlight and hue-cycling wordmark.        -->
  <!-- ============================================================ -->
  <section class="hero relative min-h-[88vh] overflow-hidden flex items-center justify-center text-brand-dark">
    <!-- warm cream paper base -->
    <div class="absolute inset-0 bg-linear-to-br from-[#f9f1de] via-[#f5e7c8] to-[#efddb6]" aria-hidden="true"></div>

    <!-- cursor-follow spotlight -->
    <div class="hero-spotlight" aria-hidden="true"></div>

    <!-- ornamental corner flourishes -->
    <span aria-hidden="true" class="absolute top-10 left-10 text-4xl text-brand-gold/40 font-heading select-none">✦</span>
    <span aria-hidden="true" class="absolute top-14 right-14 text-3xl text-brand-purple/30 select-none">✧</span>
    <span aria-hidden="true" class="absolute bottom-12 left-16 text-3xl text-brand-purple/25 select-none">✧</span>
    <span aria-hidden="true" class="absolute bottom-10 right-10 text-4xl text-brand-gold/40 font-heading select-none">✦</span>

    <!-- soft conic mesh wash -->
    <div
      class="pointer-events-none absolute -left-32 top-1/2 -translate-y-1/2 w-[60vw] h-[60vw] max-w-2xl max-h-2xl rounded-full opacity-50 blur-3xl"
      style="background: conic-gradient(from 90deg at 50% 50%, #f3d488, #e0b9d6, #c8b0e8, #b8d6c5, #f3d488);"
      aria-hidden="true"
    ></div>

    <div class="relative z-10 mx-6 w-full max-w-4xl text-center">
      <!-- logo -->
      <img
        src="/images/keyhole-mystic-publishing-logo.jpg"
        alt="Keyhole Mystic Publishing"
        class="block w-32 h-32 md:w-40 md:h-40 mx-auto rounded-full shadow-[0_25px_60px_-20px_rgba(52,4,92,0.45)] ring-1 ring-brand-gold/60 mb-8"
        loading="eager"
      />

      <p class="text-xs uppercase tracking-[0.45em] text-brand-purple/70 mb-4">The Imprint</p>
      <h1 class="text-4xl md:text-7xl font-heading leading-[1.04] mb-6">
        <span class="block hue-cycle bg-linear-to-r from-brand-purple via-brand-gold to-brand-purple bg-clip-text text-transparent">
          Keyhole Mystic
        </span>
        <span class="block hue-cycle hue-cycle-alt bg-linear-to-r from-brand-gold via-brand-purple to-brand-gold bg-clip-text text-transparent">
          Publishing
        </span>
      </h1>
      <p class="text-base md:text-xl max-w-2xl mx-auto leading-relaxed text-brand-dark/85 italic mb-9">
        {i.decks.kmpIntro}
      </p>

      <div class="flex items-center justify-center gap-3 text-brand-purple/50">
        <span class="h-px w-12 bg-brand-purple/40"></span>
        <span class="text-[10px] uppercase tracking-[0.4em]">The Catalog ↓</span>
        <span class="h-px w-12 bg-brand-purple/40"></span>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- MANIFESTO — what the imprint is. Short, declarative.          -->
  <!-- ============================================================ -->
  <section class="relative py-20 px-4 md:px-8 overflow-hidden bg-[#fbf6e8]">
    <div
      class="pointer-events-none absolute left-1/2 -top-20 -translate-x-1/2 w-[80vw] max-w-2xl h-80 rounded-[40%] opacity-50 blur-3xl"
      style="background: radial-gradient(ellipse at center, #e8c89a 0%, transparent 70%);"
      aria-hidden="true"
    ></div>
    <div class="relative max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 text-brand-purple mb-5">
        <span class="h-px w-8 bg-brand-purple/60"></span>
        <span class="text-[10px] uppercase tracking-[0.35em]">A Manifesto in One Breath</span>
        <span class="h-px w-8 bg-brand-purple/60"></span>
      </div>
      <p class="text-xl md:text-3xl leading-[1.45] text-brand-dark font-heading">
        Every work under this mantle is <em class="text-brand-purple">page-as-portal</em> —
        Kent's visionary art bound into objects you can hold,
        shuffle, read aloud, and pass down.
      </p>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- CATALOG — 2x2 grid with 3D tilt on hover.                     -->
  <!-- ============================================================ -->
  <section id="catalog" class="relative py-24 px-4 md:px-8 overflow-hidden bg-linear-to-b from-[#fbf6e8] to-[#f5e7c8]">
    <div class="relative max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs uppercase tracking-[0.35em] text-brand-purple/70 mb-3">{i.decks.kmpCatalogHeading}</p>
        <h2 class="text-3xl md:text-5xl font-heading text-brand-dark">Four titles. One mantle.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
        {catalog.map((item) => (
          <article class={`catalog-tile ${item.tilt} group relative rounded-3xl overflow-hidden bg-white/70 ring-1 ring-brand-gold/30 shadow-[0_20px_60px_-25px_rgba(52,4,92,0.35)]`}>
            <div class="relative aspect-[5/3] overflow-hidden">
              <img
                src={item.image}
                alt={item.name}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]"
                loading="lazy"
              />
              <div class={`absolute inset-0 mix-blend-overlay opacity-30 bg-linear-to-br ${item.accent}`} aria-hidden="true"></div>
              <div class="absolute inset-0 bg-linear-to-t from-black/40 via-transparent to-transparent" aria-hidden="true"></div>
            </div>
            <div class="p-6 md:p-7">
              <p class="text-[10px] uppercase tracking-[0.3em] text-brand-purple/70 mb-2">{item.sub}</p>
              <h3 class={`text-2xl md:text-3xl font-heading mb-2 bg-linear-to-r ${item.accent} bg-clip-text text-transparent`}>
                {item.name}
              </h3>
              <p class="text-brand-dark/80 leading-relaxed">{item.note}</p>
            </div>
            <!-- corner glyph -->
            <span aria-hidden="true" class="absolute top-3 right-3 text-brand-gold/80 text-lg select-none">✦</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- EL ESTIMADO — inline excerpt, presented as a parchment page.  -->
  <!-- This is the alternative to the /decks modal: same teaser,    -->
  <!-- experienced inline rather than behind a click.                -->
  <!-- ============================================================ -->
  <section class="relative py-24 px-4 md:px-8 overflow-hidden bg-linear-to-br from-[#1a0a2b] via-brand-purple to-[#3a1a0a] text-white">
    <div class="pointer-events-none absolute -top-20 -left-24 w-96 h-96 rounded-full bg-brand-gold/15 blur-3xl drift-a" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -bottom-20 -right-24 w-md h-112 rounded-full bg-fuchsia-500/15 blur-3xl drift-b" aria-hidden="true"></div>
    <span aria-hidden="true" class="absolute top-10 left-12 text-brand-gold/60 text-2xl select-none">✦</span>
    <span aria-hidden="true" class="absolute bottom-12 right-14 text-brand-gold/60 text-2xl select-none">✧</span>

    <div class="relative max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-xs uppercase tracking-[0.35em] text-brand-gold mb-3">{i.decks.kmpFeaturedEyebrow}</p>
        <h2 class="text-3xl md:text-5xl font-heading mb-3">
          <span class="bg-linear-to-r from-amber-200 via-brand-gold to-rose-300 bg-clip-text text-transparent">{i.decks.elEstimadoTitle}</span>
        </h2>
        <p class="text-amber-200/85 italic">{i.decks.elEstimadoSubtitle} · {i.decks.elEstimadoAuthor}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-[auto_1fr] gap-10 md:gap-14 items-start">
        <!-- Book covers -->
        <div class="relative mx-auto md:mx-0 w-56 md:w-72">
          <img
            src="/images/el-estimado-back.jpg"
            alt=""
            class="absolute top-2 -left-3 w-full h-auto rounded-lg ring-1 ring-white/20 shadow-[0_20px_50px_-15px_rgba(0,0,0,0.6)] rotate-3"
            loading="lazy"
            aria-hidden="true"
          />
          <img
            src="/images/el-estimado-front.jpg"
            alt="El Estimado — front cover"
            class="relative w-full h-auto rounded-lg ring-1 ring-white/30 shadow-[0_30px_70px_-20px_rgba(0,0,0,0.7)] -rotate-1"
            loading="lazy"
          />
        </div>

        <!-- Inline parchment excerpt -->
        <div class="excerpt-page relative rounded-lg p-6 md:p-10 text-[#2a1e10]">
          <p class="excerpt-eyebrow">A first read — in Kent's own words</p>
          <div class="excerpt-rule" aria-hidden="true">
            <span></span><span class="excerpt-rule-dot">✦</span><span></span>
          </div>
          <div class="excerpt-body">
            {i.decks.elEstimadoTeaser.split('\n\n').map((para: string) => (
              <p>{para}</p>
            ))}
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="flex flex-wrap justify-center gap-3 mt-12">
        <a href="/contact" class="btn-glow">{i.decks.kmpCtaReachOut}</a>
        <a href="/decks" class="btn-outline">See the festival view</a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- WHERE TO FIND — direct contact close                          -->
  <!-- ============================================================ -->
  <section id="order" class="relative py-20 px-4 md:px-8 overflow-hidden bg-[#fbf6e8]">
    <div class="relative max-w-3xl mx-auto text-center">
      <p class="text-xs uppercase tracking-[0.35em] text-brand-purple/70 mb-3">Find the Decks</p>
      <h2 class="text-2xl md:text-4xl font-heading text-brand-dark mb-5">{i.decks.whereHeading}</h2>
      <p class="text-lg leading-relaxed text-brand-dark/85 mb-7">{i.decks.whereText}</p>
      <a href="/contact" class="btn-glow">{i.decks.whereCtaContact}</a>
    </div>
  </section>
</Layout>

<style>
  /* ============================================================ */
  /* Hero spotlight: follows the cursor across the cream backdrop */
  /* ============================================================ */
  .hero {
    --spot-x: 50%;
    --spot-y: 35%;
  }
  .hero-spotlight {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 45vw 35vw at var(--spot-x) var(--spot-y),
      rgba(255, 240, 200, 0.65) 0%,
      rgba(255, 230, 180, 0.25) 35%,
      transparent 70%
    );
    transition: background-position 0.1s linear;
    pointer-events: none;
  }

  /* ============================================================ */
  /* Hue-cycle gradient text                                       */
  /* ============================================================ */
  @keyframes hue-cycle {
    0%   { filter: hue-rotate(0deg); }
    50%  { filter: hue-rotate(28deg); }
    100% { filter: hue-rotate(0deg); }
  }
  .hue-cycle {
    animation: hue-cycle 9s ease-in-out infinite;
  }
  .hue-cycle-alt {
    animation-delay: -4.5s;
  }

  /* ============================================================ */
  /* Drift orbs (shared from /decks)                              */
  /* ============================================================ */
  @keyframes drift-a {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50%      { transform: translate3d(14px, -10px, 0) scale(1.06); }
  }
  @keyframes drift-b {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50%      { transform: translate3d(-12px, 10px, 0) scale(1.08); }
  }
  .drift-a { animation: drift-a 11s ease-in-out infinite; }
  .drift-b { animation: drift-b 15s ease-in-out infinite; }

  /* ============================================================ */
  /* Catalog tile 3D tilt: each corner tilts toward center on hover*/
  /* ============================================================ */
  .catalog-tile {
    transform-style: preserve-3d;
    perspective: 1000px;
    transition: transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.45s ease;
    will-change: transform;
  }
  .catalog-tile:hover {
    box-shadow: 0 30px 80px -25px rgba(52, 4, 92, 0.55);
  }
  .tilt-tl:hover { transform: perspective(1000px) rotateX(4deg)  rotateY(-4deg) translateY(-4px); }
  .tilt-tr:hover { transform: perspective(1000px) rotateX(4deg)  rotateY(4deg)  translateY(-4px); }
  .tilt-bl:hover { transform: perspective(1000px) rotateX(-4deg) rotateY(-4deg) translateY(-4px); }
  .tilt-br:hover { transform: perspective(1000px) rotateX(-4deg) rotateY(4deg)  translateY(-4px); }

  /* ============================================================ */
  /* Inline parchment excerpt                                      */
  /* ============================================================ */
  .excerpt-page {
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(255, 245, 220, 0.9), transparent 70%),
      linear-gradient(180deg, #f7ecd1 0%, #f1e2bd 100%);
    border-radius: 6px;
    box-shadow:
      0 35px 90px -25px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      inset 0 -8px 18px -10px rgba(120, 70, 20, 0.18);
    font-family: var(--font-body, Georgia, 'Times New Roman', serif);
  }
  .excerpt-page::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background:
      repeating-linear-gradient(
        135deg,
        rgba(120, 80, 30, 0.025) 0 2px,
        transparent 2px 5px
      );
    mix-blend-mode: multiply;
  }
  .excerpt-page::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0; left: 0;
    width: 14px;
    border-radius: 6px 0 0 6px;
    background: linear-gradient(90deg, rgba(110, 65, 25, 0.22), transparent);
    pointer-events: none;
  }
  .excerpt-eyebrow {
    text-align: center;
    font-style: italic;
    color: #8a5a1e;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  .excerpt-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin: 0.5rem 0 1.5rem;
  }
  .excerpt-rule span:first-child,
  .excerpt-rule span:last-child {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, #b88a3e, transparent);
    max-width: 120px;
  }
  .excerpt-rule-dot {
    color: #b88a3e;
    font-size: 0.9rem;
  }
  .excerpt-body p {
    font-size: 1.02rem;
    line-height: 1.85;
    color: #2a1e10;
    margin-bottom: 1.15rem;
    text-align: justify;
    hyphens: auto;
  }
  .excerpt-body p:first-of-type::first-letter {
    font-family: var(--font-heading, Georgia, serif);
    font-size: 3.4rem;
    line-height: 0.9;
    float: left;
    padding: 0.35rem 0.65rem 0 0;
    color: #8a5a1e;
    font-weight: 700;
  }
  .excerpt-body p:last-of-type { margin-bottom: 0; }

  /* ============================================================ */
  /* Buttons                                                        */
  /* ============================================================ */
  .btn-glow {
    display: inline-block;
    padding: 0.9rem 1.6rem;
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
    color: #140a18;
    background-image: linear-gradient(135deg, #ffd773, #ff8fb2 55%, #a78bfa);
    border-radius: 9999px;
    box-shadow: 0 12px 40px -10px rgba(255, 143, 178, 0.65);
    transition: transform 0.25s ease, box-shadow 0.25s ease, filter 0.25s ease;
  }
  .btn-glow:hover {
    transform: translateY(-2px);
    filter: brightness(1.07);
    box-shadow: 0 18px 50px -12px rgba(167, 139, 250, 0.6);
  }

  .btn-outline {
    display: inline-block;
    padding: 0.9rem 1.6rem;
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(6px);
    transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }
  .btn-outline:hover {
    background: rgba(255, 255, 255, 0.95);
    color: #140a18;
    border-color: #fff;
  }

  @media (prefers-reduced-motion: reduce) {
    .hue-cycle, .drift-a, .drift-b { animation: none; }
    .catalog-tile { transition: none; }
    .catalog-tile:hover { transform: none; }
  }
</style>

<script>
  // Hero spotlight follows the cursor.
  const hero = document.querySelector<HTMLElement>('.hero');
  if (hero) {
    const update = (event: PointerEvent) => {
      const rect = hero.getBoundingClientRect();
      const x = ((event.clientX - rect.left) / rect.width) * 100;
      const y = ((event.clientY - rect.top) / rect.height) * 100;
      hero.style.setProperty('--spot-x', `${x}%`);
      hero.style.setProperty('--spot-y', `${y}%`);
    };
    hero.addEventListener('pointermove', update);
    hero.addEventListener('pointerleave', () => {
      hero.style.setProperty('--spot-x', '50%');
      hero.style.setProperty('--spot-y', '35%');
    });
  }
</script>
