---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionBlock from '../components/SectionBlock.astro';
import { t } from '../i18n';

const i = t('en');
---

<Layout title={i.gatherings.title}>
  <Hero heading={i.nav.gatherings} />

  <SectionBlock heading={i.gatherings.mushroomHeading}>
    <div class="space-y-4 text-base leading-relaxed">
      <p>{i.gatherings.mushroomText1}</p>
      <p>{i.gatherings.mushroomText2}</p>
      <p>{i.gatherings.mushroomText3}</p>
      <p>{i.gatherings.mushroomText4}</p>
    </div>
  </SectionBlock>

  <div class="border-t border-brand-light"></div>

  <SectionBlock heading={i.gatherings.ayahuascaHeading}>
    <div class="space-y-4 text-base leading-relaxed">
      <p>{i.gatherings.ayahuascaText1}</p>
      <p>{i.gatherings.ayahuascaText2}</p>
      <p>{i.gatherings.ayahuascaText3}</p>
    </div>
  </SectionBlock>

  <div class="border-t border-brand-light"></div>

  <SectionBlock heading={i.gatherings.testimonialHeading}>
    <blockquote class="text-lg md:text-xl italic text-center text-brand-warm-gray max-w-2xl mx-auto">
      {i.gatherings.testimonial}
    </blockquote>
  </SectionBlock>
</Layout>
