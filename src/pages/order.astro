---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionBlock from '../components/SectionBlock.astro';
import OrderForm from '../components/OrderForm.astro';
import { t } from '../i18n';

const i = t('en');
---

<Layout title={i.order.title} description={i.order.metaDescription} noindex>
  <Hero heading={i.order.heading} />

  <SectionBlock>
    <p class="text-center text-lg leading-relaxed mb-3 max-w-2xl mx-auto">{i.order.intro}</p>
    <p class="text-center text-base italic text-brand-purple mb-10 max-w-2xl mx-auto">{i.order.noObligation}</p>
    <OrderForm />
  </SectionBlock>
</Layout>
